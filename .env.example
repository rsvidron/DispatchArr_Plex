# Dispatcharr server — no IP is hardcoded in code; set one of the options below.
# Option A (recommended): full base URL, no trailing slash.
DISPATCHARR_BASE_URL=http://localhost:9191

# Option B: omit BASE_URL and set host (and optional port) instead — handy across machines.
# DISPATCHARR_SCHEME=http
# DISPATCHARR_HOST=192.168.1.10
# DISPATCHARR_PORT=9191

# Prefer API key (Profile in UI): long-lived for scripts
DISPATCHARR_API_KEY=

# Or JWT login:
# DISPATCHARR_USERNAME=
# DISPATCHARR_PASSWORD=

DISPATCHARR_TIMEOUT=120

# reserve_nufu_live_block.py + nufu_live_slot_maintenance.py (optional)
# DISPATCHARR_NUFU_M3U_ACCOUNT_ID=2
# DISPATCHARR_NUFU_LIVE_PREFIX=Nufu Live Games
# DISPATCHARR_NUFU_LIVE_STREAM_GROUP=Live-Games
# DISPATCHARR_NUFU_LIVE_MAX_SLOTS=50
# DISPATCHARR_NUFU_LIVE_SYNC_TVG_ID=1
#   When mapping live games, set each slot channel's tvg_id to the stream's
#   tvg_id (or name) so XMLTV/clients can match programme data by id.
