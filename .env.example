# Dispatcharr server — no IP is hardcoded in code; set one of the options below.
# Option A (recommended): full base URL, no trailing slash.
DISPATCHARR_BASE_URL=http://localhost:9191

# Option B: omit BASE_URL and set host (and optional port) instead — handy across machines.
# DISPATCHARR_SCHEME=http
# DISPATCHARR_HOST=192.168.1.10
# DISPATCHARR_PORT=9191

# Prefer API key (Profile in UI): long-lived for scripts
DISPATCHARR_API_KEY=

# Or JWT login:
# DISPATCHARR_USERNAME=
# DISPATCHARR_PASSWORD=

DISPATCHARR_TIMEOUT=120

# reserve_nufu_live_block.py + nufu_live_slot_maintenance.py (optional)
# DISPATCHARR_NUFU_M3U_ACCOUNT_ID=2
# DISPATCHARR_NUFU_LIVE_PREFIX=Nufu Live Games
# DISPATCHARR_NUFU_LIVE_STREAM_GROUP=Live-Games
#   Used for channel_group_id when creating/fixing Nufu Live Games channels (must match playlist).
# DISPATCHARR_NUFU_LIVE_MAX_SLOTS=51
# DISPATCHARR_NUFU_LIVE_CHANNEL_START=500
#   With defaults, live games use dials 500..550; leave 1–100 for manual channels.
# DISPATCHARR_NUFU_MAIN_LIBRARY_START=101
#   After reserve_nufu_live_block.py, automated non-game channels start here (dials 1–100 left for manual).
# DISPATCHARR_NUFU_LIVE_SYNC_TVG_ID=1
#   When mapping live games, set each slot channel's tvg_id to the stream's
#   tvg_id (or name) so XMLTV/clients can match programme data by id.
# DISPATCHARR_NUFU_LIVE_SYNC_CHANNEL_NAME=1
#   When mapping live games, PATCH each slot channel's display name to the game/stream title
#   so Plex and other clients show the event in the guide; cleared slots revert to "Nufu Live Games NN".
# DISPATCHARR_NUFU_LIVE_CHANNEL_NAME_TEMPLATE={title}
#   Placeholders: {title}, {slot}, {slot:02d} — e.g. Ch {slot:02d}: {title}
#
# Live-Channels block (sync_streams_after_m3u.py --map-nufu-live-channels):
# Stable Plex order: nufu_live_channels_mapping.json (slot -> tvg_id or name).
# Create once: py -3 map_nufu_live_channels.py --write-initial-mapping
# MODE=by_channel_number maps onto existing channels at each dial (default from CHANNEL_START); avoids duplicate placeholders.
# placeholders = create "Nufu Live Channels NN" rows (only if you do not already have channels at those numbers).
# DISPATCHARR_NUFU_LIVE_CHANNELS_MODE=by_channel_number
# DISPATCHARR_NUFU_LIVE_CHANNELS_MAPPING=./nufu_live_channels_mapping.json
# DISPATCHARR_NUFU_LIVE_CHANNELS_ORDERED_FALLBACK=0
# DISPATCHARR_NUFU_LIVE_CHANNELS_PREFIX=Nufu Live Channels
# DISPATCHARR_NUFU_LIVE_CHANNELS_STREAM_GROUP=Live-Channels
# DISPATCHARR_NUFU_LIVE_CHANNELS_MAX_SLOTS=100
# DISPATCHARR_NUFU_LIVE_CHANNELS_CHANNEL_START=101
#   Slot 1 = dial 101; dials 1–100 reserved for channels you add by hand in Dispatcharr.
# DISPATCHARR_NUFU_LIVE_CHANNELS_SYNC_TVG_ID=1
# DISPATCHARR_NUFU_LIVE_CHANNELS_SYNC_CHANNEL_NAME=1
#   PATCH channel display name to the matched stream title (Plex/guide); cleared slots -> placeholder name.
# DISPATCHARR_NUFU_LIVE_CHANNELS_CHANNEL_NAME_TEMPLATE={title}
